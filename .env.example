# Frontend — safe to expose (VITE_ prefix)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# NEVER put these in .env for the frontend:
# SUPABASE_SERVICE_ROLE_KEY → Supabase Vault only
# STRIPE_SECRET_KEY → Supabase Vault only
# STRIPE_WEBHOOK_SECRET → Supabase Vault only
# RESEND_API_KEY → Supabase Vault only
